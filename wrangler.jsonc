{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "avito-reklama-etagi",
  "main": "src/index.js",
  "compatibility_date": "2024-12-18",
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": true,
      "persist": true,
      "head_sampling_rate": 1
    }
  }
}
